{
  "name": "antigravity-copy-full",
  "displayName": "Antigravity Copy Full Conversation",
  "description": "Copy Antigravity, Claude Cowork, and Claude Code conversations including the full thought process, extended thinking, and reasoning to clipboard as Markdown",
  "version": "1.6.0",
  "publisher": "henriquepasquini2",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/henriquepasquini2/antigravity-copy-extension"
  },
  "bugs": {
    "url": "https://github.com/henriquepasquini2/antigravity-copy-extension/issues"
  },
  "homepage": "https://github.com/henriquepasquini2/antigravity-copy-extension#readme",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "antigravity",
    "google",
    "claude",
    "claude-code",
    "cowork",
    "anthropic",
    "chat",
    "conversation",
    "thoughts",
    "reasoning",
    "thinking",
    "copy",
    "export",
    "markdown"
  ],
  "activationEvents": [
    "onCommand:antigravity-copy-full.copyConversation",
    "onCommand:antigravity-copy-full.copyConversationWithPrompts",
    "onCommand:antigravity-copy-full.dumpTrajectory",
    "onCommand:antigravity-copy-full.claudeCopySession",
    "onCommand:antigravity-copy-full.claudeCopySessionWithPrompts",
    "onCommand:antigravity-copy-full.claudeDumpSession",
    "onCommand:antigravity-copy-full.claudeCodeCopySession",
    "onCommand:antigravity-copy-full.claudeCodeCopySessionWithPrompts",
    "onCommand:antigravity-copy-full.claudeCodeDumpSession"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-copy-full.copyConversation",
        "title": "Copy Full Conversation",
        "category": "Antigravity"
      },
      {
        "command": "antigravity-copy-full.copyConversationWithPrompts",
        "title": "Copy Full Conversation with Prompts",
        "category": "Antigravity"
      },
      {
        "command": "antigravity-copy-full.dumpTrajectory",
        "title": "Dump Raw Trajectory (Debug)",
        "category": "Antigravity"
      },
      {
        "command": "antigravity-copy-full.claudeCopySession",
        "title": "Copy Full Session",
        "category": "Claude Cowork"
      },
      {
        "command": "antigravity-copy-full.claudeCopySessionWithPrompts",
        "title": "Copy Full Session with Prompts",
        "category": "Claude Cowork"
      },
      {
        "command": "antigravity-copy-full.claudeDumpSession",
        "title": "Dump Raw Session (Debug)",
        "category": "Claude Cowork"
      },
      {
        "command": "antigravity-copy-full.claudeCodeCopySession",
        "title": "Copy Full Session",
        "category": "Claude Code"
      },
      {
        "command": "antigravity-copy-full.claudeCodeCopySessionWithPrompts",
        "title": "Copy Full Session with Prompts",
        "category": "Claude Code"
      },
      {
        "command": "antigravity-copy-full.claudeCodeDumpSession",
        "title": "Dump Raw Session (Debug)",
        "category": "Claude Code"
      }
    ],
    "keybindings": [
      {
        "command": "antigravity-copy-full.copyConversation",
        "key": "ctrl+shift+alt+c",
        "mac": "cmd+shift+alt+c"
      },
      {
        "command": "antigravity-copy-full.copyConversationWithPrompts",
        "key": "ctrl+shift+alt+p",
        "mac": "cmd+shift+alt+p"
      },
      {
        "command": "antigravity-copy-full.claudeCopySession",
        "key": "ctrl+shift+alt+l",
        "mac": "cmd+shift+alt+l"
      },
      {
        "command": "antigravity-copy-full.claudeCopySessionWithPrompts",
        "key": "ctrl+shift+alt+k",
        "mac": "cmd+shift+alt+k"
      },
      {
        "command": "antigravity-copy-full.claudeCodeCopySession",
        "key": "ctrl+shift+alt+j",
        "mac": "cmd+shift+alt+j"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.105.0",
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.10",
    "typescript": "^6.0.2"
  }
}
